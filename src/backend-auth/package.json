{
  "name": "chessguard-auth",
  "version": "1.0.0",
  "main": "dist/app.js",
  "scripts": {
    "dev": "prisma generate && tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:generate": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^25.9.4",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "typescript": "^5.4.5"
  },
  "overrides": {
    "@hono/node-server": "^1.19.13"
  },
  "allowScripts": {
    "prisma@7.8.0": true,
    "@prisma/client@7.8.0": true,
    "@prisma/engines@7.8.0": true,
    "bcrypt@6.0.0": true,
    "esbuild@0.28.1": true
  }
}
