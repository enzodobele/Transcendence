{
  "name": "chessguard-game",
  "version": "1.0.0",
  "main": "dist/app.js",
  "scripts": {
    "dev": "prisma generate && tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "db:generate": "prisma generate",
    "format": "npx prettier --write \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/cors": "^2.8.19",
    "bcrypt": "^6.0.0",
    "chess.js": "^1.4.0",
    "cors": "^2.8.6",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "prom-client": "^15.1.3",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.5.12",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "typescript": "^5.4.5"
  },
  "overrides": {
    "@hono/node-server": "^1.19.13"
  },
  "allowScripts": {
    "prisma@7.8.0": true,
    "@prisma/client@7.8.0": true,
    "@prisma/engines@7.8.0": true,
    "bcrypt@6.0.0": true,
    "esbuild@0.28.1": true
  }
}